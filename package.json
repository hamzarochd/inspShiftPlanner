{
  "name": "inps_shiftplanner",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.29"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-inps_shiftplanner": "cds watch --open inpsshiftplanner/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy inps_shiftplanner --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "hybrid": "cds watch --profile hybrid"
  },
  "private": true,
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa",
        "db": "hana"
      }
    },
    "fiori": {
      "preview": true
    },
    "server": {
      "index": true
    }
  },
  "workspaces": [
    "app/*"
  ]
}
