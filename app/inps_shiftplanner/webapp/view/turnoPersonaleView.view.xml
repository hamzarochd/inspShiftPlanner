<mvc:View xmlns:cards="sap.f.cards"
    controllerName="inpsshiftplanner.controller.turnoPersonale"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout" 
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified">

    <f:DynamicPage>

        <!-- Inizio Pagina -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Profilo Personale"/>
                </f:heading>
                <f:expandedContent>
                    <Text text="Visualizza turni e informazioni personali"/>
                </f:expandedContent>
            </f:DynamicPageTitle>
        </f:title>

        <!-- CONTENUTO -->
        <f:content>
            <VBox class="sapUiMediumMargin">

                <!-- CARD PROFILO -->
                <f:Card class="cardProfile sapUiMediumMarginBotton"> <!-- Capire sapUiMediumMarginBotton e anche f:card-->

                    <f:content>
                        <FlexBox justifyContent="SpaceBetween" alignItems="Center" wrap="Wrap" class="sapUiMediumMargin"> <!--Capire SapMediumMrgin-->

                            <!-- Profilo-->
                            <VBox class="sapUiMediumMarginEnd">
                                <Avatar initials="MR" displaySize="XL" backgroundColor="Accent6"/> <!-- capire "Accent6"-->
                                <Title text="Mario Rossi" class="sapUiSmallMarginTop" titleStyle="H4"/> <!-- H4?-->
                                <Text text="Matricola: INF-2458"/>
                            </VBox>

                            <!-- INFO -->
                            <FlexBox wrap="Wrap" width="70%" justifyContent="SpaceBetween"> <!-- Cambiato width-->

                                <HBox class="infoItem">
                                    <core:Icon src="sap-icon://briefcase" class="icon blue"/>
                                    <VBox>
                                        <Text text="RUOLO" class="label"/>
                                        <Text text="Infermiere" class="value"/> <!-- da cambiare funzione text più avanti, collegandolo al db-->
                                    </VBox>
                                </HBox>

                                <HBox class="infoItem">
                                    <core:Icon src="sap-icon://map-marker" class="icon purple"/>
                                    <VBox>
                                        <Text text="REPARTO" class="label"/>
                                        <Text text="Terapia Intensiva" class="value"/>
                                    </VBox>
                                </HBox>

                                <HBox class="infoItem">
                                    <core:Icon src="sap-icon://email" class="icon green"/>
                                    <VBox>
                                        <Text text="EMAIL" class="label"/>
                                        <Text text="mario.rossi@ospedale.it" class="value"/>
                                    </VBox>
                                </HBox>

                                <HBox class="infoItem">
                                    <core:Icon src="sap-icon://call" class="icon orange"/>
                                    <VBox>
                                        <Text text="TELEFONO" class="label"/>
                                        <Text text="+39 348 123 4567" class="value"/>
                                    </VBox>
                                </HBox>

                                <HBox class="infoItem">
                                    <core:Icon src="sap-icon://calendar" class="icon violet"/>
                                    <VBox>
                                        <Text text="ASSUNTO DAL" class="label"/>
                                        <Text text="15/03/2020" class="value"/>
                                    </VBox>
                                </HBox>

                                <HBox class="infoItem">
                                    <core:Icon src="sap-icon://employee" class="icon green"/>
                                    <VBox>
                                        <Text text="STATO" class="label"/>
                                        <ObjectStatus text="Attivo" state="Success"/>
                                    </VBox>
                                </HBox>
                            </FlexBox>
                        </FlexBox>
                    </f:content>
                </f:Card>

                <!--Card Gruppo-->
                <f:Card class="sapUiMediumMarginBottom cardProfile">
                    <f:header>
                        <cards:Header
                        title="Team A- Terapia Intensiva"
                        subtitle="6 membri-Coordinatore :"
                        iconSrc="sap-icon://group-2"/>
                    </f:header>

                    <f:content>
                        <FlexBox  wrap="Wrap"  justifyContent="Start" class="sapUiSmallMargin">
                          <HBox class ="teamMemberCard currentMember">
                                <Avatar initials="MR" displaySize="S" class="sapUiTinyMarginEnd"/>
                                <VBox >
                                <HBox  alignItems="Center">
                                    <Title text="Mario Rossi" class="value"/>
                                    <ObjectStatus text="Tu" state="Information"  class="sapUiTinyMarginBegin"/>
                                </HBox>
                                <Text  text="Cordinatore" class="label"/>
                            </VBox>
                           </HBox>

                           <HBox class ="teamMemberCard ">
                                <Avatar initials="GV" displaySize="S" class="sapUiTinyMarginEnd"/>
                                <VBox>
                                    <Text text="Giulia Verdi" class="value"/>
                                    <Text text="Infermiera"  class="label"/>
                                </VBox>
                             </HBox>

                            <HBox class ="teamMemberCard ">
                                <Avatar initials="PN" displaySize="S" class="sapUiTinyMarginEnd"/>
                                <VBox>
                                    <Text text="Paolo Neri" class="value"/>
                                    <Text text="Infermiere"  class="label"/>
                                </VBox>
                            </HBox>

                            <HBox class ="teamMemberCard ">
                                <Avatar initials="SG" displaySize="S" class="sapUiTinyMarginEnd"/>
                                <VBox>
                                    <Text text="Sara Gialli" class="value"/>
                                    <Text text="OSS"  class="label"/>
                                </VBox>
                            </HBox>

                           <HBox class ="teamMemberCard ">
                                <Avatar initials="MB" displaySize="S" class="sapUiTinyMarginEnd"/>
                                <VBox>
                                    <Text text="Marco Blu" class="value"/>
                                    <Text text="OSS"  class="label"/>
                                </VBox>
                            </HBox>
                            <HBox class ="teamMemberCard ">
                                <Avatar initials="EB" displaySize="S" class="sapUiTinyMarginEnd"/>
                                <VBox>
                                    <Text text="Elena Bianchi" class="value"/>
                                    <Text text="Medico Specializzando"  class="label"/>
                                </VBox>
                            </HBox>

                        </FlexBox>
                    </f:content>
                </f:Card>

                <!-- KPI -->
                <FlexBox wrap="Wrap" justifyContent="SpaceBetween" class="sapUiSmallMargin"> 

                    <!-- Ore -->
                    <VBox class="kpiCard blue>Card">
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <core:Icon src="sap-icon://history" class="kpiIcon"/>
                            <Title text="Ore Lavorate (Marzo)"/>
                        </HBox>

                        <HBox alignItems="End">
                            <Text text="0/168 ore" class="sapUiSmallMarginBegin"/>
                        </HBox>

                        <ProgressIndicator percentValue="0"/>
                    </VBox>

                    <!-- Turni -->
                    <VBox class="kpiCard green">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://calendar" class="kpiIcon"/>
                            <Title text="Turni Completati"/>
                        </HBox>

                        <HBox alignItems="End">
                           <Text text="0/ 21 turni" class="sapUiSmallMarginBegin"/>
                        </HBox>

                        <ProgressIndicator percentValue="0"/>  <!--state=""(usalo per segnalare un  successo)-->
                    </VBox>

                    <!-- Ferie -->
                    <VBox class="kpiCard purple">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://calendar" class="kpiIcon"/>
                            <Title text="Ferie e Recuperi"/>
                        </HBox>

                        <FlexBox wrap="Wrap" width="600px" justifyContent="SpaceBetween"> <!--Simple form-->
                         <HBox  justifyContent="SpaceBetween" width="55%">
                            <VBox >
                            <Title text="Ferie residue"/>
                            <Text text="12 giorni"/>
                            </VBox>

                            <VBox>
                            <Title text="Recuperi"/>
                            <Text text="8 ore"/>
                            </VBox>
                        </HBox>
                        </FlexBox>
                    </VBox>

                </FlexBox>

                <!--Calendario-->
                <Panel headerText="I miei turni" class="sapUiMediumMarginTop">

                    <PlanningCalendar
                        id="PlanningCalendar"
                        startDate="{/startDate}"
                        viewKey="One Month"
                        rows="{/dipendenti}">

                        <rows>
                            <PlanningCalendarRow
                                title="{name}"
                                text="{role}"
                                appointments="{path: 'shifts'}">

                                <appointments>
                                    <unified:CalendarAppointment
                                        startDate="{startDate}"
                                        endDate="{endDate}"
                                        title="{title}"
                                        color="{color}"/>
                                </appointments>

                            </PlanningCalendarRow>
                        </rows>

                    </PlanningCalendar>

                </Panel>

            </VBox>
        </f:content>

    </f:DynamicPage>

</mvc:View>