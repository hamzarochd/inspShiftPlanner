<mvc:View 
    xmlns:cards="sap.f.cards"
    controllerName="inpsshiftplanner.controller.turnoPersonale"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:l-="sap.ui.layout" 
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified">

    <f:DynamicPage>
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Profilo Personale"/>
                </f:heading>
                <f:expandedContent>
                    <Text text="Visualizza turni e informazioni personali"/>
                </f:expandedContent>
                <f:actions>
                    <Button 
                    id="btnIndietro"
                    text="Torna alla Pianificazione"
                    icon="sap-icon://nav-back"
                    type="Transparent"
                    press="onNavBack"/>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
            <VBox class="sapUiMediumMargin">

                <f:Card class="cardProfile sapUiMediumMarginBottom">
                    <f:content>
                        <FlexBox justifyContent="Start" alignItems="Start" wrap="Wrap" class="sapUiMediumMargin">

                            <VBox width="400px" class="sapUiMediumMarginEnd sapUiSmallMarginBottom">
                                <Avatar initials="MB" displaySize="XL" backgroundColor="Accent6"/>
                                <Title text="{odata>Name} {odata>Surname}" class="sapUiSmallMarginTop" titleStyle="H4"/>
                                <Text text="Matricola: INF-2458"/>
                            </VBox>
<!-- Info-->
                            <FlexBox  justifyContent="SpaceBetween" wrap="Wrap">
                                
                                <VBox width="400px" class="sapUiSmallMarginBottom">
                                    <HBox class="infoItem sapUiMediumMarginBottom">
                                        <core:Icon src="sap-icon://briefcase" class="icon blue"/>
                                        <VBox>
                                            <Text text="RUOLO" class="label" wrapping="false"/>
                                            <Text text="{odata>Role}" class="value" wrapping="false"/>
                                        </VBox>
                                    </HBox>
                                    <HBox class="infoItem sapUimediumMarginBottom">
                                        <core:Icon src="sap-icon://email" class="icon green"/>
                                        <VBox>
                                            <Text text="EMAIL" class="label" wrapping="false"/>
                                            <Text text="mario.rossi@ospedale.it" class="value" wrapping="false"/>
                                        </VBox>
                                    </HBox>
                                    <HBox class="infoItem">
                                        <core:Icon src="sap-icon://calendar" class="icon violet"/>
                                        <VBox>
                                            <Text text="ASSUNTO DAL" class="label" wrapping="false"/>
                                            <Text text="15/03/2020" class="value" wrapping="false"/>
                                        </VBox>
                                    </HBox>
                                </VBox>

                                <VBox width="400px" class="sapUiSmallMarginBottom">
                                    <HBox class="infoItem sapUiMediumMarginBottom">
                                        <core:Icon src="sap-icon://map-marker" class="icon purple"/>
                                        <VBox>
                                            <Text text="REPARTO" class="label" wrapping="false"/>
                                            <Text text="Terapia Intensiva" class="value" wrapping="false"/>
                                        </VBox>
                                    </HBox>
                                    <HBox class="infoItem sapUimediumMarginBottom">
                                        <core:Icon src="sap-icon://call" class="icon orange"/>
                                        <VBox>
                                            <Text text="TELEFONO" class="label" wrapping="false"/>
                                            <Text text="+39 348 123 4567" class="value" wrapping="false"/>
                                        </VBox>
                                    </HBox>
                                    <HBox class="infoItem">
                                        <core:Icon src="sap-icon://employee" class="icon green"/>
                                        <VBox>
                                            <Text text="STATO" class="label" wrapping="false"/>
                                            <ObjectStatus text="Attivo" state="Success"/>
                                        </VBox>
                                    </HBox>
                                </VBox>

                                <VBox width="300px"  class="sapUimediumMarginBottom">
                                    <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                        <core:Icon src="sap-icon://comment" class="icon orange"/>
                                        <Text text="NOTE E COMUNICAZIONI" class="label" wrapping="false" />
                                    </HBox>
                                    <VBox class="notesContainer">
                                        <Text
                                            text="{odata>NoteRicevute}" 
                                            wrapping="true"
                                            class="receivedNoteText"/>
                                    </VBox>
                                </VBox>
                            </FlexBox>
                        </FlexBox>
                    </f:content>
                </f:Card>

                <f:Card class="sapUiMediumMarginBottom cardProfile">
                    <f:header>
                        <cards:Header
                            title="Team A - Terapia Intensiva"
                            subtitle="6 membri • Coordinatore: Dr. Laura Bianchi"
                            iconSrc="sap-icon://group-2"/>
                    </f:header>
<!-- Gruppo-->
                    <f:content>
                        <FlexBox wrap="Wrap" justifyContent="Start" class="sapUiSmallMargin">
                            <HBox class="teamMemberCard currentMember">
                                <Avatar initials="MR" displaySize="S" class="sapUiTinyMarginEnd"/>
                                <VBox>
                                    <HBox alignItems="Center">
                                        <Text text="Mario Rossi" class="value"/>
                                        <ObjectStatus text="Tu" state="Information" class="sapUiTinyMarginBegin"/>
                                    </HBox>
                                    <Text text="Coordinatore" class="label"/>
                                </VBox>
                            </HBox>

                            <HBox class="teamMemberCard">
                                <Avatar initials="GV" displaySize="S" class="sapUiTinyMarginEnd"/>
                                <VBox>
                                    <Text text="Giulia Verdi" class="value"/>
                                    <Text text="Infermiera" class="label"/>
                                </VBox>
                            </HBox>

                            <HBox class="teamMemberCard">
                                <Avatar initials="PN" displaySize="S" class="sapUiTinyMarginEnd"/>
                                <VBox>
                                    <Text text="Paolo Neri" class="value"/>
                                    <Text text="Infermiere" class="label"/>
                                </VBox>
                            </HBox>

                            <HBox class="teamMemberCard">
                                <Avatar initials="SG" displaySize="S" class="sapUiTinyMarginEnd"/>
                                <VBox>
                                    <Text text="Sara Gialli" class="value"/>
                                    <Text text="OSS" class="label"/>
                                </VBox>
                            </HBox>

                            <HBox class="teamMemberCard">
                                <Avatar initials="MB" displaySize="S" class="sapUiTinyMarginEnd"/>
                                <VBox>
                                    <Text text="Marco Blu" class="value"/>
                                    <Text text="OSS" class="label"/>
                                </VBox>
                            </HBox>

                            <HBox class="teamMemberCard">
                                <Avatar initials="EB" displaySize="S" class="sapUiTinyMarginEnd"/>
                                <VBox>
                                    <Text text="Elena Bianchi" class="value"/>
                                    <Text text="Medico Specializzando" class="label"/>
                                </VBox>
                            </HBox>
                        </FlexBox>
                    </f:content>
                </f:Card>

                <FlexBox wrap="Wrap" justifyContent="SpaceBetween" class="kpiContainer"> 
<!--Ore-->                   
                    <VBox class="kpiCard">
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <core:Icon src="sap-icon://history" class="icon blue"/>
                            <Title text="Ore Lavorate (Marzo)" titleStyle="H6"/>
                        </HBox>
                        <HBox justifyContent="SpaceBetween" alignItems="End" class="sapUiTinyMarginBottom">
                            <Text text="156 / 168 ore" class="valueKPI"/>
                            <Text text="92%" class="percentLabel"/>
                        </HBox>
                        <ProgressIndicator percentValue="92" displayValue="" state="Information" height="8px"/>
                    </VBox>
<!--Turni-->
                    <VBox class="kpiCard">
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <core:Icon src="sap-icon://calendar" class="icon green"/>
                            <Title text="Turni Completati" titleStyle="H6"/>
                        </HBox>
                         <ProgressIndicator
					      percentValue="30"
					      displayValue="30%"
					      showValue="true"
					      state="None"/>
                    </VBox>
<!--Ferie e recuperi-->
                    <VBox class="kpiCard">
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <core:Icon src="sap-icon://accidental-leave" class="icon purple"/>
                            <Title text="Ferie e Recuperi" titleStyle="H6"/>
                        </HBox>
                        <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginTop">
                            <VBox>
                                <Text text="FERIE RESIDUE" class="label"/>
                                <Text text="12 giorni" class="valueKPI"/>
                            </VBox>
                            <VBox alignItems="End">
                                <Text text="RECUPERI" class="label"/>
                                <Text text="8 ore" class="valueKPI" />
                            </VBox>
                        </HBox>
                    </VBox>
                </FlexBox>

                <f:DynamicPage >
                    <f:header>
                    </f:header>
                    <f:content>
                        <SinglePlanningCalendar
                        id="SPC1"
                        class="sapUiSmallMargin"
                        title="Turni di :{ odata>Name } {odata>Surname}"
                        appointments="{odata>Appointments}">
                        <views>
                         <SinglePlanningCalendarMonthView key="MonthView" title="Mese" />
                        </views>
                            <appointments>
                                <unified:CalendarAppointment
                                title= "{odata>title}"
                                text= "{odata>notes}"
                                icon= "{odata>shiftIcon}"
                                startDate= "{odata>startDate}"
                                endDate= "{odata>endDate}"
                                type="{path:'odata>type',formatter:'.formatType'}">
                                </unified:CalendarAppointment>
                            </appointments>
			            </SinglePlanningCalendar>
                    </f:content>
                </f:DynamicPage>
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>