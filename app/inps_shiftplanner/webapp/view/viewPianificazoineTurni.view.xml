<mvc:View controllerName="inpsshiftplanner.controller.viewPianificazoineTurni"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar">
    <Page id="page">

        <f:DynamicPage id="turniDynamicPage" headerExpanded="true" toggleHeaderOnTitleClick="true">
            <f:title>
                <f:DynamicPageTitle>
                    <f:heading>
                        <Title text="Pianificazione Turni" />
                    </f:heading>
                    <f:expandedContent>
                        <Label text="Gestione Turni Mensili"></Label>
                    </f:expandedContent>
                </f:DynamicPageTitle>
            </f:title>
            

            <f:header>
                <f:DynamicPageHeader pinnable="false">
                    <f:content>
                        <VBox >
                            <fb:FilterBar>
                                <!-- Antonio FILTERBAR-->
                            </fb:FilterBar>
                            <HBox >
                                <!-- Chenyu KPIS -->
                            </HBox>
                        </VBox>
                    </f:content>
                </f:DynamicPageHeader>
            </f:header>

            <f:content>
                <VBox>
                    <PlanningCalendar 
                        id="planningCalendar"
                        startDate="{mockdata>/startDate}"
                        rows="{mockdata>/rows}"
                        viewKey="One Month"
                        appointmentsVisualization="Standard">
                        <rows>
                            <PlanningCalendarRow
                                icon=""
                                title=""
                                text=""
                                enableAppointmentsDragAndDrop="{path:'name', formatter:'.canModifyAppointments'}"
                                enableAppointmentsCreate="{path:'name', formatter:'.canModifyAppointments'}"
                                appointmentDrop="handleAppointmentDrop"
                                appointmentDragEnter="handleAppointmentDragEnter"
                                appointmentResize="handleAppointmentResize"
                                appointmentCreate="handleAppointmentCreate"
                                appointments="">
                                <!-- <appointments>
                                    <unified:CalendarAppointment
                                        startDate="{start}"
                                        endDate="{end}"
                                        icon="{pic}"
                                        title="{title}"
                                        text="{info}"
                                        type="{type}"
                                        tentative="{tentative}">
                                
                                    </unified:CalendarAppointment>
                                </appointments> -->
                            </PlanningCalendarRow>
                        </rows>
                    
                    </PlanningCalendar>
                </VBox>
            </f:content>
        </f:DynamicPage>

    </Page>
</mvc:View>