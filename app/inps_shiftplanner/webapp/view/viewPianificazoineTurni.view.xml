<mvc:View controllerName="inpsshiftplanner.controller.viewPianificazoineTurni"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:card="sap.f.cards"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:unified="sap.ui.unified">
    <!-- Aggiunto xmlns:unified per usare CalendarAppointment nel PlanningCalendar -->

    <Page id="page">

        <dependents>
            <ResponsivePopover
                id="appointmentPopover"
                title="{appt>/name}"
                placement="Auto">
                <content>
                    <VBox class="sapUiSmallMargin sapUiSmallMarginEnd">
                        <Label text="Tipo turno" design="Bold" />
                        <Text text="{appt>/type}" class="sapUiTinyMarginBottom" />
                        <Label text="Inizio" design="Bold" class="sapUiTinyMarginTop" />
                        <Text text="{appt>/startDate}" class="sapUiTinyMarginBottom" />
                        <Label text="Fine" design="Bold" class="sapUiTinyMarginTop" />
                        <Text text="{appt>/endDate}" />
                    </VBox>
                </content>
                <footer>
                    <Toolbar>
                        <Button icon="sap-icon://delete" type="Reject" press="onDeleteAppointment" tooltip="Elimina" />
                        <Button icon="sap-icon://edit" press="onEditAppointment" tooltip="Modifica" />
                        <ToolbarSpacer />
                        <Button icon="sap-icon://decline" press="onClosePopover" tooltip="Chiudi" />
                    </Toolbar>
                </footer>
            </ResponsivePopover>

            <Dialog id="editAppointmentDialog" title="Modifica Turno">
                <content>
                    <VBox class="sapUiSmallMargin sapUiSmallMarginEnd">
                        <Label text="Tipo turno" design="Bold" />
                        <Select
                            selectedKey="{editAppt>/type}"
                            change="onEditTypeChange"
                            width="100%"
                            class="sapUiTinyMarginBottom"
                            items="{ruoliModel>/TipiTurno}">
                            <core:Item key="{ruoliModel>key}" text="{ruoliModel>text}" />
                        </Select>
                        <Label text="Inizio" design="Bold" class="sapUiTinyMarginTop" />
                        <DateTimePicker
                            id="editStartPicker"
                            dateValue="{editAppt>/startDate}"
                            displayFormat="dd/MM/yyyy HH:mm"
                            class="sapUiTinyMarginBottom" />
                        <Label text="Fine" design="Bold" class="sapUiTinyMarginTop" />
                        <DateTimePicker
                            id="editEndPicker"
                            dateValue="{editAppt>/endDate}"
                            displayFormat="dd/MM/yyyy HH:mm" />
                    </VBox>
                </content>
                <beginButton>
                    <Button icon="sap-icon://save" text="Salva" type="Emphasized" press="onSaveEditAppointment" />
                </beginButton>
                <endButton>
                    <Button icon="sap-icon://decline" text="Annulla" press="onCancelEditAppointment" />
                </endButton>
            </Dialog>
            <Dialog id="createAppointmentDialog" title="Nuovo Turno">
                <content>
                    <VBox class="sapUiSmallMargin sapUiSmallMarginEnd">
                        <Label text="Tipo turno" design="Bold" />
                        <Select
                            id="newTypeSelect"
                            selectedKey="{newAppt>/type}"
                            forceSelection="false"
                            change="onNewTypeChange"
                            width="100%"
                            class="sapUiTinyMarginBottom"
                            items="{ruoliModel>/TipiTurno}">
                            <core:Item key="{ruoliModel>key}" text="{ruoliModel>text}" />
                        </Select>
                        <Label text="Inizio" design="Bold" class="sapUiTinyMarginTop" />
                        <DateTimePicker
                            id="newStartPicker"
                            dateValue="{newAppt>/startDate}"
                            displayFormat="dd/MM/yyyy HH:mm"
                            class="sapUiTinyMarginBottom" />
                        <Label text="Fine" design="Bold" class="sapUiTinyMarginTop" />
                        <DateTimePicker
                            id="newEndPicker"
                            dateValue="{newAppt>/endDate}"
                            displayFormat="dd/MM/yyyy HH:mm" />
                    </VBox>
                </content>
                <beginButton>
                    <Button icon="sap-icon://add" text="Crea" type="Emphasized" press="onSaveNewAppointment" />
                </beginButton>
                <endButton>
                    <Button icon="sap-icon://decline" text="Annulla" press="onCancelNewAppointment" />
                </endButton>
            </Dialog>
        </dependents>

        <f:DynamicPage id="turniDynamicPage" headerExpanded="true" toggleHeaderOnTitleClick="true">
            <f:title>
                <f:DynamicPageTitle>
                    <f:heading>
                        <Title text="{i18n>titolo}" />
                    </f:heading>
                    <f:expandedContent>
                        <Label text="Gestione e monitoraggio turni del personale"></Label>
                    </f:expandedContent>
                </f:DynamicPageTitle>
            </f:title>


            <f:header>
                <f:DynamicPageHeader pinnable="false">
                    <f:content>
                        <VBox>
                            <fb:FilterBar id="shiftFilterBar"
                                reset="onResetFilters"
                                clear="onResetFilters"
                                search="onSearch"
                                useToolbar="false"
                                showGoOnFB="true"
                                class="sapUiBottomMargin"
                                showClearOnFB="true"
                                showFilterConfiguration="false">
                                <fb:filterGroupItems>

                                    <!--Ruolo-->
                                    <fb:FilterGroupItem
                                        groupName="Main"
                                        name="Ruolo"
                                        label="Ruoli"
                                        visibleInFilterBar="true">
                                        <fb:control>
                                            <ComboBox
                                                id="roleFilterCombo"
                                                width="100%"
                                                items="{ruoliModel>/RuoliCollezione}"
                                                placeholder="Seleziona ruolo"
                                                showClearIcon="true">
                                                <core:Item key="{ruoliModel>key}"
                                                    text="{ruoliModel>text}" />
                                            </ComboBox>
                                        </fb:control>
                                    </fb:FilterGroupItem>

                                    <!--Reparti-->
                                    <fb:FilterGroupItem
                                        groupName="cd"
                                        name="Reparti"
                                        label="Reparti"
                                        visibleInFilterBar="true">
                                        <fb:control>
                                            <ComboBox
                                                id="repartoFilterCombo"
                                                width="100%"
                                                items="{ruoliModel>/Reparti}"
                                                placeholder="Seleziona reparto"
                                                showClearIcon="true">
                                                <core:Item key="{ruoliModel>key}"
                                                    text="{ruoliModel>text}" />
                                            </ComboBox>
                                        </fb:control>
                                    </fb:FilterGroupItem>

                                    <!--Dipartimenti-->
                                    <fb:FilterGroupItem
                                        groupName="cd"
                                        name="Dipartimenti"
                                        label="Dipartimenti"
                                        visibleInFilterBar="true">
                                        <fb:control>
                                            <ComboBox
                                                id="Dipartimenti"
                                                width="100%"
                                                items="{ruoliModel>/Dipartimenti}"
                                                placeholder="Seleziona dipartimento"
                                                showClearIcon="true">
                                                <core:Item key="{ruoliModel>Dipartimento}"
                                                    text="{ruoliModel>Dipartimento}" />
                                            </ComboBox>
                                        </fb:control>
                                    </fb:FilterGroupItem>
                                </fb:filterGroupItems>
                            </fb:FilterBar>
                            <HBox
                                class="sapUiSmallMarginEnd sapUiSmallMarginTop sapUiSmallMarginBottom">
                                <!-- Chenyu KPIS -->
                                <GenericTile class="" header="Mancanza personale"
                                    frameType="OneByHalf" press="onPressMancanzaPersonale"
                                    wrappingType="Hyphenated">
                                    <TileContent>
                                        <NumericContent scale="G" value="{kpi>/understaffedDays}"
                                            valueColor="Error" indicator="Up" withMargin="false" />
                                    </TileContent>
                                </GenericTile>

                                <GenericTile class="sapUiTinyMarginBegin" header="Rischio salute"
                                    frameType="OneByHalf" press="onPressRischioSalute">
                                    <TileContent>
                                        <NumericContent scale="P" value="{kpi>/consecutiveCount}"
                                            valueColor="Error" indicator="Up" withMargin="false" />
                                    </TileContent>
                                </GenericTile>

                                <!-- card: avere almeno un giorno di riposto alla settimana-->

                                <GenericTile class="sapUiTinyMarginBegin" header="Mancanza riposo"
                                    frameType="OneByHalf" press="onPressMancazaRiposso"
                                    wrappingType="Hyphenated">
                                    <TileContent>
                                        <NumericContent scale="P"
                                            value="{kpi>/personaleSenzaMinimoRiposoCount}"
                                            valueColor="Error" indicator="Up" withMargin="false" />
                                    </TileContent>
                                </GenericTile>


                            </HBox>
                        </VBox>
                    </f:content>
                </f:DynamicPageHeader>
            </f:header>

            <f:content>
                <VBox>
                    <PlanningCalendar
                        id="planningCalendar"
                        rows="{path: '/dipendenti'}"
                        startDate="{/startDate}"
                        viewKey="One Month"
                        appointmentsVisualization="Standard"
                        showEmptyIntervalHeaders="false"
                        appointmentHeight="Regular"
                        appointmentSelect="onAppointmentSelect"
                        intervalSelect="onIntervalSelect">

                        <rows>
                            <PlanningCalendarRow
                                icon="{= ${highlight} ? 'sap-icon://message-warning' : ${icon} }"
                                title="{name}"
                                text="{role}"
                                nonWorkingDays=""
                                appointments="{path: 'shifts', templateShareable: false}"
                                enableAppointmentsDragAndDrop="true"
                                enableAppointmentsResize="false"
                                appointmentDrop="handleAppointmentDrop">
                                <customData>
                                    <core:CustomData
                                        key="myHighlight"
                                        value="{= ${highlight} ? 'true' : 'false' }"
                                        writeToDom="true" />
                                </customData>
                                <appointments>
                                    <unified:CalendarAppointment
                                        startDate="{startDate}"
                                        endDate="{endDate}"
                                        icon="{= ${type} === 'AFFIANCAMENTO' ? 'sap-icon://collaborate'    :
                                                  ${type} === 'DIAGNOSTICA'   ? 'sap-icon://stethoscope'   :
                                                  ${type} === 'EMERGENZA'     ? 'sap-icon://alert'         :
                                                  ${type} === 'REPERIBILITA'  ? 'sap-icon://phone'         :
                                                  ${type} === 'RIPOSO'        ? 'sap-icon://bed'           :
                                                  ${type} === 'COORDINAMENTO' ? 'sap-icon://manager'       : '' }"
                                        color="{color}"
                                        tooltip="{title}">
                                    </unified:CalendarAppointment>
                                </appointments>
                            </PlanningCalendarRow>
                        </rows>
                    </PlanningCalendar>
                </VBox>
            </f:content>
        </f:DynamicPage>

    </Page>
</mvc:View>