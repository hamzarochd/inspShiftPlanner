<mvc:View controllerName="inpsshiftplanner.controller.viewPianificazoineTurni"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
	xmlns:core="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar">
    <Page id="page">

        <f:DynamicPage id="turniDynamicPage" headerExpanded="true" toggleHeaderOnTitleClick="true">
            <f:title>
                <f:DynamicPageTitle>
                    <f:heading>
                        <Title text="Pianificazione Turni" />
                    </f:heading>
                    <f:expandedContent>
                        <Label text="Gestione Turni Mensili"></Label>
                    </f:expandedContent>
                </f:DynamicPageTitle>
            </f:title>
            

            <f:header>
                <f:DynamicPageHeader pinnable="false">
                    <f:content>
                        <VBox >
                            <fb:FilterBar>
                                <!-- Antonio FILTERBAR-->
                            </fb:FilterBar>
                            <HBox >
                                <!-- Chenyu KPIS -->
                                <GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="Mancanza personale"
                                            frameType = "OneByHalf" press="">
                                    <TileContent>
                                        <NumericContent scale="M" value="{kpi>/understaffedDays}" valueColor="Error" indicator="Up" withMargin="false" />
                                    </TileContent>
                                </GenericTile>

                                <GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="Rischio salute"
                                            frameType = "OneByHalf" press="">
                                    <TileContent>
                                        <NumericContent scale="M" value="" valueColor="Error" indicator="Up" withMargin="false" />
                                    </TileContent>
                                </GenericTile>

                                <GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="terzo titole"
                                            frameType = "OneByHalf" press="">
                                    <TileContent>
                                        <NumericContent scale="M" value="" valueColor="Error" indicator="Up" withMargin="false" />
                                    </TileContent>
                                </GenericTile>

                            </HBox>
                        </VBox>
                    </f:content>
                </f:DynamicPageHeader>

                <!-- HAMZA PLANNING CALENDAR -->

            </f:header>
        </f:DynamicPage>

    </Page>
</mvc:View>