<mvc:View controllerName="inpsshiftplanner.controller.viewPianificazoineTurni"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:card="sap.f.cards"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:unified="sap.ui.unified">
    <!-- Aggiunto xmlns:unified per usare CalendarAppointment nel PlanningCalendar -->

    <Page id="page">

        <f:DynamicPage id="turniDynamicPage" headerExpanded="true" toggleHeaderOnTitleClick="true">
            <f:title>
                <f:DynamicPageTitle>
                    <f:heading>
                        <Title text="{i18n>titolo}" />
                    </f:heading>
                    <f:expandedContent>
                        <Label text="Gestione e monitoraggio turni del personale"></Label>
                    </f:expandedContent>
                </f:DynamicPageTitle>
            </f:title>


            <f:header>
                <f:DynamicPageHeader pinnable="false">
                    <f:content>
                        <VBox >
                            <fb:FilterBar id="shiftFilterBar"
                                          reset="onResetFilters"
                                          clear="onResetFilters"
                                          search="onSearch"
                                          useToolbar="false"
                                          showGoOnFB="true"
                                          class="sapUiBottomMargin"
                                          showClearOnFB="true"
                                          showFilterConfiguration="false">
                            <fb:filterGroupItems>

                                      <!--Ruolo-->
                                  <fb:FilterGroupItem 
                                     groupName="Main" 
                                     name="Ruolo" 
                                     label="Ruoli" 
                                     visibleInFilterBar="true">
                                   <fb:control>
                                   <ComboBox  
                                     id="roleFilterCombo" 
                                     width="100%" 
                                     items="{ruoliModel>/RuoliCollezione}" 
                                     placeholder="Seleziona ruolo" 
                                     showClearIcon="true">
                                      <core:Item key="{ruoliModel>key}"  text="{ruoliModel>text}" />
                                   </ComboBox>
                                   </fb:control>
                                </fb:FilterGroupItem>

                                  <!--Reparti-->
                                <fb:FilterGroupItem  
                                     groupName="cd" 
                                     name="Reparti" 
                                     label="Reparti" 
                                     visibleInFilterBar="true">
                                   <fb:control>
                                   <ComboBox  
                                     id="repartoFilterCombo" 
                                     width="100%" 
                                     items="{ruoliModel>/Reparti}" 
                                     placeholder="Seleziona reparto" 
                                     showClearIcon="true">
                                     <core:Item key="{ruoliModel>key}" text="{ruoliModel>text}" />
                                   </ComboBox>
                                   </fb:control>
                                  </fb:FilterGroupItem>
                                </fb:filterGroupItems>
                            </fb:FilterBar>
                            <HBox class = "sapUiSmallMarginEnd sapUiSmallMarginTop sapUiSmallMarginBottom">
                                <!-- Chenyu KPIS -->
                                <GenericTile class="" header="Mancanza personale"
                                            frameType = "OneByHalf" press="onPressMancanzaPersonale" wrappingType="Hyphenated">
                                    <TileContent>
                                        <NumericContent scale="G" value="{kpi>/understaffedDays}" valueColor="Error" indicator="Up" withMargin="false" />
                                    </TileContent>
                                </GenericTile>

                                <GenericTile class="sapUiTinyMarginBegin" header="Rischio salute"
                                            frameType = "OneByHalf" press="onPressRischioSalute">
                                    <TileContent>
                                        <NumericContent scale="P" value="{kpi>/consecutiveCount}" valueColor="Error" indicator="Up" withMargin="false" />
                                    </TileContent>
                                </GenericTile>

                                <!-- card: avere almeno un giorno di riposto alla settimana-->

                                <GenericTile class="sapUiTinyMarginBegin" header="Mancanza riposo"
                                            frameType = "OneByHalf" press="onPressMancazaRiposso" wrappingType="Hyphenated">
                                    <TileContent>
                                        <NumericContent scale="P" value="{kpi>/personaleSenzaMinimoRiposoCount}" valueColor="Error" indicator="Up" withMargin="false" />
                                    </TileContent>
                                </GenericTile>

<!--
                                <GenericTile class="sapUiTinyMarginBegin" header="Composizione Staff"
                                            frameType = "OneByHalf" press="">
                                    <TileContent>
                                        <NumericContent scale="M" value="" valueColor="Error" indicator="Up" withMargin="false" />
                                    </TileContent>
                                </GenericTile>-->

                            </HBox>
                        </VBox>
                    </f:content>
                </f:DynamicPageHeader>
            </f:header>

            <f:content>
                <VBox>
                    <PlanningCalendar
                        id="planningCalendar"
                        rows="{path: '/staffs'}"
                        startDate="{/startDate}"
                        viewKey="One Month"
                        appointmentsVisualization="Standard"
                        showEmptyIntervalHeaders="false"
                        appointmentHeight="Regular">

                        <rows>
                            <PlanningCalendarRow
                                icon="{= ${highlight} ? 'sap-icon://message-warning' : ${icon} }"                              
                                title="{name}"
                                text="{role}"
                                nonWorkingDays=""
                                appointments="{path: 'shifts', templateShareable: false}"
                                enableAppointmentsDragAndDrop="true"
                                enableAppointmentsResize="false">
                                <customData>
                                    <core:CustomData 
                                        key="myHighlight" 
                                        value="{= ${highlight} ? 'true' : 'false' }" 
                                        writeToDom="true" />
                                </customData>
                                <appointments>
                                    <unified:CalendarAppointment
                                        startDate="{startDate}"
                                        endDate="{endDate}"
                                        icon="{shiftIcon}"
                                        color="{color}"
                                        tooltip="{title}">
                                    </unified:CalendarAppointment>
                                </appointments>
                            </PlanningCalendarRow>
                        </rows>
                    </PlanningCalendar>
                </VBox>
            </f:content>
        </f:DynamicPage>

    </Page>
</mvc:View>
