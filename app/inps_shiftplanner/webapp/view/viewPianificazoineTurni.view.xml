<mvc:View controllerName="inpsshiftplanner.controller.viewPianificazoineTurni"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:card="sap.f.cards"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:unified="sap.ui.unified">
    <!-- Aggiunto xmlns:unified per usare CalendarAppointment nel PlanningCalendar -->

    <Page id="page">

        <f:DynamicPage id="turniDynamicPage" headerExpanded="true" toggleHeaderOnTitleClick="true">
            <f:title>
                <f:DynamicPageTitle>
                    <f:heading>
                        <Title text="{i18n>titolo}" />
                    </f:heading>
                    <f:expandedContent>
                        <Label text="Gestione e monitoraggio turni del personale"></Label>
                    </f:expandedContent>
                </f:DynamicPageTitle>
            </f:title>


            <f:header>
                <f:DynamicPageHeader pinnable="false">
                    <f:content>
                        <VBox >
                            <fb:FilterBar id="shiftFilterBar"
                                          reset="onResetFilters"
                                          clear="onResetfilters"
                                          search="onSearch"
                                          useToolbar="false"
                                          showGoOnFB="true"
                                          class="sapUiBottomMargin"
                                          showClearOnFB="true"
                                          showFilterConfiguration="false">

                                <fb:filterGroupItems>
                                  <fb:FilterGroupItem groupName="Main" name="Ruolo" label="Ruolo" visibleInFilterBar="true">
                                   <fb:control>
                                   <ComboBox  id="roleFilterCombo" items="{ruoliModel>/RuoliCollezione}">
                                      <core:Item key="{ruoliModel>key}" text="{ruoliModel>text}" />
                                   </ComboBox>
                                   </fb:control>

                                  </fb:FilterGroupItem>
                                  <fb:FilterGroupItem  groupName="cd" name="Reparti" label="Reparti" visibleInFilterBar="true">
                                   <fb:control>
                                   <ComboBox  id="" items="{ruoliModel>/Reparti}">
                                      <core:Item key="{ruoliModel>key}" text="{ruoliModel>text}" />
                                   </ComboBox>
                                   </fb:control>
                                  </fb:FilterGroupItem>
                                </fb:filterGroupItems>
                            </fb:FilterBar>
                            <HBox >
                                <!-- Chenyu KPIS -->
                                <GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="Mancanza personale"
                                            frameType = "OneByHalf" press="">
                                    <TileContent>
                                        <NumericContent scale="M" value="{kpi>/understaffedDays}" valueColor="Error" indicator="Up" withMargin="false" />
                                    </TileContent>
                                </GenericTile>

                                <GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="Rischio salute"
                                            frameType = "OneByHalf" press="">
                                    <TileContent>
                                        <NumericContent scale="M" value="" valueColor="Error" indicator="Up" withMargin="false" />
                                    </TileContent>
                                </GenericTile>

                                <GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="terzo titole"
                                            frameType = "OneByHalf" press="">
                                    <TileContent>
                                        <NumericContent scale="M" value="" valueColor="Error" indicator="Up" withMargin="false" />
                                    </TileContent>
                                </GenericTile>

                            </HBox>
                        </VBox>
                    </f:content>
                </f:DynamicPageHeader>
            </f:header>

            <f:content>
                <VBox>
                    <!-- PlanningCalendar collegato al modello "mockdata":
                         startDate legge il campo "date" dalla radice del JSON,
                         rows itera sull'array "Staff" (ogni elemento diventa una riga) -->
                    <PlanningCalendar
                        id="planningCalendar"
                        startDate="{mockdata>/date}"
                        rows="{mockdata>/Staff}"
                        viewKey="One Month"
                        appointmentsVisualization="Standard">
                        <rows>
                            <!-- Ogni PlanningCalendarRow corrisponde a un membro dello Staff.
                                 I binding sono relativi all'elemento corrente di mockdata>/Staff:
                                 title = "name", text = "role", icon = "icon" -->
                            <PlanningCalendarRow
                                icon="{icon}"
                                title="{name}"
                                text="{role}">
                                
                                <!-- enableAppointmentsDragAndDrop="{path:'name', formatter:'.canModifyAppointments'}"
                                enableAppointmentsCreate="{path:'name', formatter:'.canModifyAppointments'}"
                                appointmentDrop="handleAppointmentDrop"
                                appointmentDragEnter="handleAppointmentDragEnter"
                                appointmentResize="handleAppointmentResize"
                                appointmentCreate="handleAppointmentCreate"> -->
                                
                                
                                <!-- Gli appuntamenti vengono letti dall'array "shifts" di ogni membro.
                                     startDate e endDate usano il tipo DateTime per la conversione,
                                     title, text, icon (shiftIcon) e type mappano i campi del turno -->
                                <appointments>
                                    <unified:CalendarAppointment
                                        startDate="{path: 'startDate', type: 'sap.ui.model.type.DateTime'}"
                                        endDate="{path: 'endDate', type: 'sap.ui.model.type.DateTime'}"
                                        title="{title}"
                                        text="{text}"
                                        icon="{shiftIcon}"
                                        type="{type}">
                                    </unified:CalendarAppointment>
                                </appointments>
                            </PlanningCalendarRow>
                        </rows>

                    </PlanningCalendar>
                </VBox>
            </f:content>
        </f:DynamicPage>

    </Page>
</mvc:View>
